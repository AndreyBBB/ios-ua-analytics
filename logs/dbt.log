-- One row per (creative_id, stat_date).
-- Adds day_of_life, rolling 7-day CTR, and peak CTR for burnout scoring.

with ad_stats as (
    select * from `marts_staging`.`stg_ad_stats`
),

creatives as (
    select * from `marts_staging`.`stg_creatives`
),

campaigns as (
    select * from `marts_staging`.`stg_campaigns`
),

enriched as (
    select
        s.stat_date,
        s.campaign_id,
        s.creative_id,
        s.network,
        s.country,
        c.creative_name,
        c.format,
        c.format_group,
        c.is_video,
        c.launch_date,
        camp.objective,
        dateDiff('day', c.launch_date, s.stat_date)   as day_of_life,
        s.impressions,
        s.clicks,
        s.spend_usd,
        s.installs,
        s.ctr,
        s.cvr_click_to_install,
        s.cpi_usd,
        s.cpm_usd,
        s.cpc_usd
    from ad_stats s
    inner join creatives c   ON c.creative_id   = s.creative_id
    inner join campaigns camp ON camp.campaign_id = s.campaign_id
    where s.stat_date >= c.launch_date
),

