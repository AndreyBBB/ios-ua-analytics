    inner join creatives c   ON c.creative_id   = s.creative_id
    inner join campaigns camp ON camp.campaign_id = s.campaign_id
    where s.stat_date >= c.launch_date
),

-- Explicit column list avoids ClickHouse wildcard/window scope ambiguity
with_rolling as (
    select
        stat_date,
        campaign_id,
        creative_id,
        network,
        country,
        creative_name,
        format,
        format_group,
        is_video,
        launch_date,
        objective,
        day_of_life,
        impressions,
        clicks,
        spend_usd,
        installs,
        ctr,
        cvr_click_to_install,
        cpi_usd,
        cpm_usd,
        cpc_usd,

        avg(ctr) over (
            partition by creative_id
            order by stat_date
            rows between 6 preceding and current row
        )                                               as ctr_7d_avg,

        max(ctr) over (
            partition by creative_id
            order by stat_date
            rows between unbounded preceding and current row
        )                                               as ctr_peak_so_far,

        sum(spend_usd) over (
            partition by creative_id
            order by stat_date
            rows between unbounded preceding and current row
        )                                               as cumulative_spend_usd,

        sum(installs) over (
            partition by creative_id
            order by stat_date
            rows between unbounded preceding and current row
        )                                               as cumulative_installs

    from enriched
)

select * from with_rolling
