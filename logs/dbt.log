            -- int_cohort_revenue
-- ─────────────────────────────────────────────────────────────────────────────
-- Revenue aggregated by (install_date, campaign_id, days_since_install).
-- This powers the LTV curve and payback period calculations.
--
-- Pattern: for each install cohort, sum up revenue that arrived on
-- days 0, 1, 3, 7, 14, 30 etc. after install.

with iap as (
    select * from `marts_staging`.`stg_iap_events`
    where is_revenue_event = true     -- exclude trials (no revenue)
),

cohort_installs as (
    select * from `marts_intermediate`.`int_cohort_installs`
),

-- Revenue by cohort + cohort day
revenue_by_day as (
    select
        iap.install_date,
        iap.campaign_id,
        iap.creative_id,
        iap.network,
        iap.country,
        iap.days_since_install,
        iap.event_type,
        iap.product_tier,

        count()                                             as event_count,
        sum(iap.revenue_usd)                               as revenue_usd

    from iap
    group by 1, 2, 3, 4, 5, 6, 7, 8
),

-- Cumulative revenue by cohort day (for LTV curve)
-- Uses window function to accumulate revenue over cohort lifetime
cumulative_revenue as (
    select
        r.install_date,
        r.campaign_id,
        r.creative_id,
        r.network,
        r.country,
        r.days_since_install,

        -- Daily revenue for this cohort
        sum(r.revenue_usd)                                  as daily_revenue_usd,

        -- Cumulative revenue up to this day
        sum(sum(r.revenue_usd)) over (
            partition by r.install_date, r.campaign_id, r.creative_id
            order by r.days_since_install
            rows between unbounded preceding and current row
        )                                                   as cumulative_revenue_usd,

        -- Join cohort size for per-user metrics
        any(ci.cohort_installs)                             as cohort_installs,
        any(ci.cohort_spend_usd)                            as cohort_spend_usd,
        any(ci.cac_usd)                                     as cac_usd

    from revenue_by_day r
    left join cohort_installs ci
        using (install_date, campaign_id, creative_id)
    group by 1, 2, 3, 4, 5, 6
),

-- Add per-user LTV and ROAS at each cohort day
with_ltv as (
    select
        *,
        -- LTV per user at this cohort day
        round(
            cumulative_revenue_usd / nullif(cohort_installs, 0),
            4
        )                                                   as ltv_usd,

        -- ROAS at this cohort day (cumulative revenue / cohort spend)
        round(
            cumulative_revenue_usd / nullif(cohort_spend_usd, 0),
            4
        )                                                   as roas

    from cumulative_revenue
)

select * from with_ltv
          )
        
