            -- int_creative_daily_metrics
-- ─────────────────────────────────────────────────────────────────────────────
-- One row per (creative_id, stat_date).
-- Joins ad stats with creative metadata to add:
--   - day_of_life:   how many days since this creative launched
--   - rolling 7-day CTR:   for smoothed burnout calculation
--   - peak CTR so far:     reference point for burnout scoring
--
-- This is the foundation for mart_creative_burnout.

with ad_stats as (
    select * from `marts_staging`.`stg_ad_stats`
),

creatives as (
    select * from `marts_staging`.`stg_creatives`
),

campaigns as (
    select * from `marts_staging`.`stg_campaigns`
),

-- Join ad stats with creative + campaign metadata
enriched as (
    select
        s.stat_date,
        s.campaign_id,
        s.creative_id,
        s.network,
        s.country,
        c.creative_name,
        c.format,
        c.format_group,
        c.is_video,
        c.launch_date,
        camp.objective,

        -- Day of life: how many days has this creative been running?
        dateDiff('day', c.launch_date, s.stat_date)     as day_of_life,

        -- Raw metrics
        s.impressions,
        s.clicks,
        s.spend_usd,
        s.installs,
        s.ctr,
        s.cvr_click_to_install,
        s.cpi_usd,
        s.cpm_usd,
        s.cpc_usd

    from ad_stats s
    inner join creatives c  ON c.creative_id  = s.creative_id
    inner join campaigns camp ON camp.campaign_id = s.campaign_id
    where
        s.stat_date >= c.launch_date    -- only include days after launch
        and s.impressions >= 0
),

-- Add window functions for rolling stats and peak tracking
with_rolling as (
    select
        *,

        -- 7-day rolling average CTR (smooths daily noise for burnout detection)
        avg(ctr) over (
            partition by creative_id
            order by stat_date
            rows between 6 preceding and current row
        )                                               as ctr_7d_avg,

        -- Cumulative peak CTR (highest CTR seen so far in this creative's life)
        max(ctr) over (
            partition by creative_id
            order by stat_date
            rows between unbounded preceding and current row
        )                                               as ctr_peak_so_far,

        -- Total cumulative spend on this creative
        sum(spend_usd) over (
            partition by creative_id
            order by stat_date
            rows between unbounded preceding and current row
        )                                               as cumulative_spend_usd,

        -- Total cumulative installs
        sum(installs) over (
            partition by creative_id
            order by stat_date
            rows between unbounded preceding and current row
        )                                               as cumulative_installs

    from enriched
)

select * from with_rolling
          )
        
