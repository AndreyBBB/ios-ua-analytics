-- One row per (creative_id, stat_date).
-- Adds day_of_life, rolling 7-day CTR, and cumulative spend/installs.
--
-- ClickHouse note: CTEs with JOINs cause column scope ambiguity in window
-- functions. Flat single-SELECT with table-qualified aliases avoids this entirely.

select
    s.stat_date,
    s.campaign_id,
    s.creative_id,
    s.network,
    s.country,
    c.creative_name,
    c.format,
    c.format_group,
    c.is_video,
    c.launch_date,
    camp.objective,
    dateDiff('day', c.launch_date, s.stat_date)     as day_of_life,
    s.impressions,
    s.clicks,
    s.spend_usd,
    s.installs,
    s.ctr,
    s.cvr_click_to_install,
    s.cpi_usd,
    s.cpm_usd,
    s.cpc_usd,

    -- 7-day rolling average CTR (smooths daily noise for burnout detection)
    avg(s.ctr) over (
        partition by s.creative_id
        order by s.stat_date
        rows between 6 preceding and current row
    )                                               as ctr_7d_avg,

    -- Cumulative peak CTR seen so far in this creative's life
    max(s.ctr) over (
        partition by s.creative_id
        order by s.stat_date
        rows between unbounded preceding and current row
    )                                               as ctr_peak_so_far,

    -- Total cumulative spend on this creative
    sum(s.spend_usd) over (
        partition by s.creative_id
        order by s.stat_date
        rows between unbounded preceding and current row
    )                                               as cumulative_spend_usd,

    -- Total cumulative installs
    sum(s.installs) over (
        partition by s.creative_id
        order by s.stat_date
        rows between unbounded preceding and current row
    )                                               as cumulative_installs

from `marts_staging`.`stg_ad_stats` s
inner join `marts_staging`.`stg_creatives` c   ON c.creative_id   = s.creative_id
inner join `marts_staging`.`stg_campaigns` camp ON camp.campaign_id = s.campaign_id
where s.stat_date >= c.launch_date
