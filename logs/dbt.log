        installs,
        ctr,
        cvr_click_to_install,
        cpi_usd,
        cpm_usd,
        cpc_usd,

        avg(ctr) over (
            partition by creative_id
            order by stat_date
            rows between 6 preceding and current row
        )                                               as ctr_7d_avg,

        max(ctr) over (
            partition by creative_id
            order by stat_date
            rows between unbounded preceding and current row
        )                                               as ctr_peak_so_far,

        sum(spend_usd) over (
            partition by creative_id
            order by stat_date
            rows between unbounded preceding and current row
        )                                               as cumulative_spend_usd,

        sum(installs) over (
            partition by creative_id
            order by stat_date
            rows between unbounded preceding and current row
        )                                               as cumulative_installs

    from enriched
)

